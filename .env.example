# API keys live here or in shell env.
# Model/provider structure lives in registries/models/*.jsonl.

# OpenAI-compatible APIs
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Gemini generateContent API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# OpenRouter via OpenAI-compatible adapter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Local OpenAI-compatible endpoint
CKL_LOCAL_BASE_URL=http://127.0.0.1:8000/v1
CKL_LOCAL_MODEL=local-model
CKL_LOCAL_API_KEY=local

# DSv4 registered provider. Public DeepSeek OpenAI-format base URL:
DSV4_BASE_URL=https://api.deepseek.com
DSV4_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DSV4_MODEL=deepseek-v4-flash
DSV4_MAX_TOKENS=2048
DSV4_API_KEY=
DEEPSEEK_API_KEY=

# Optional judge model for expectations with {"kind":"judge"}.
# Use "same" to reuse the tested model, or a registered/API target like deepseekv4.
CKL_JUDGE=

# Optional command-agent wrappers. Each command must read ckl-bench JSON from stdin.
CKL_AGENT_COMMAND=
CKL_CODEX_COMMAND=
CKL_CLAUDE_COMMAND=python scripts/claude_code_wrapper.py
CKL_GEMINI_COMMAND=

# Claude Code wrapper. Endpoint must support Anthropic Messages API format.
CKL_CLAUDE_COMMAND=claude
CKL_CLAUDE_MODEL=deepseek-v4-flash
CKL_CLAUDE_WORKSPACE_DIR=.tmp-runs/claude-code-workspaces
